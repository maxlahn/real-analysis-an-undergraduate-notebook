  <title>
    Orders from pullbacks
  </title>
  
  <task>
    <statement>
      <p>
        Prove that the pullback of a preorder is a preorder.
      </p>
    </statement>
    
    <hint>
      <p>
        You may find it useful to review the proof of <xref ref="lemma-preorders-from-pullbacks"/>.
      </p>
    </hint>
    
    <solution>
