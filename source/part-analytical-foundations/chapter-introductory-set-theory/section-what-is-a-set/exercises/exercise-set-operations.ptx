<?xml version="1.0" encoding="UTF-8"?>

<exercise xml:id="exercise-set-operations" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>
    Set Operations
  </title>
  
  <introduction>
    <p>
      Compute the given set operations. Write your answer in roster or set-builder notation, or as a well-known set.
    </p>
  </introduction>
  
  <task>
    <statement>
      <p>
        Compute <m> S \cap T </m>, where
        
        <md>
          S = \setmid{ n \in \N }{ n = 2 k \textrm{ for some } k \in \N } = \set{ 0 , 2 , 4 , 6 , \dotsc } 
        </md>
        
        is the set of even natural numbers and
        
        <md>
          T = \setmid{ n \in \N }{ n = 2 k + 1 \textrm{ for some } k \in \N } = \set{ 1 , 3 , 5 , 7 , \dotsc } 
        </md>
        
        is the set of odd integers.
      </p>
    </statement>
    
    <answer>
      <p>
        <m> S \cap T = \emptyset </m>.
      </p>
    </answer>
    
    <solution>
      <p>
        No natural number is both even and odd, and so <m> S \cap T = \emptyset </m>.
      </p>
    </solution>
  </task>
  
  <task>
    <statement>
      <p>
        Compute <m> S \cup T </m>, where <m> S = \set{ 0 , 3 , 4 , 9 } </m> and <m> T = \set{ 1 , 3 , 6 } </m>.
      </p>
    </statement>
    
    <answer>
      <p>
        <m> S \cup T = \set{ 0 , 1 , 3 , 4 , 6 , 9 } </m>.
      </p>
    </answer>
    
    <solution>
      <p>
        <m> S \cup T </m> contains all the elements of <m> S </m> and all the elements of <m> T </m>, so that <m> S \cup T = \set{ 0 , 1 , 3 , 4 , 6 , 9 } </m>.
      </p>
    </solution>
  </task>
  
  <task>
    <statement>
      <p>
        Compute <m> S \setminus T </m>, where
        
        <md>
          S = \setmid{ n \in \N }{ n = 5 k \textrm{ for some } k \in \N } = \set{ 0 , 5 , 10 , 15 , \dotsc }
        </md>
        
        is the set of natural numbers divisible by <m> 5 </m>, and
        
        <md>
          T = \setmid{ n \in \N }{ n = 2 k \textrm{ for some } k \in \N } = \set{ 0 , 2 , 4 , 6 , \dotsc }
        </md>
        
        is the set of even natural numbers.
      </p>
    </statement>
    
    <answer>
      <p>
        <m> S \setminus T = \setmid{ n \in \N }{ n = 10 k + 5 \textrm{ for some } k \in \N } = \set{ 5 , 15 , 25 , 35 , \dotsc } </m>.
      </p>
    </answer>
    
    <solution>
      <p>
        <m> S \setminus T </m> contains all the odd multiples of <m> 5 </m>, so that
        
        <md>
          <mrow>
            S \setminus T \amp = \setmid{ n \in \N }{ n = 10 k + 5 \textrm{ for some } k \in \N }
          </mrow>
          
          <mrow>
            \amp = \set{ 5 , 15 , 25 , 35 , \dotsc }
          </mrow>
        </md>.
      </p>
    </solution>
  </task>
</exercise>
